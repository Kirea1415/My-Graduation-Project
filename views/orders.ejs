<script>
// Apply dynamic styles to status badges
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.status-badge[data-bg-color]').forEach(function(badge) {
    const bgColor = badge.getAttribute('data-bg-color');
    const textColor = badge.getAttribute('data-text-color');
    const borderColor = badge.getAttribute('data-border-color');
    badge.style.setProperty('--status-bg', bgColor);
    badge.style.setProperty('--status-color', textColor);
    badge.style.setProperty('--status-border', borderColor);
  });
});

// Copy key functionality
document.addEventListener('DOMContentLoaded', function() {
  // Copy button click
  document.querySelectorAll('.btn-copy-key[data-key-value]').forEach(button => {
    button.addEventListener('click', function() {
      const keyValue = this.getAttribute('data-key-value');
      copyKeyToClipboard(keyValue, this);
    });
  });

  // Click on key value to select
  document.querySelectorAll('.key-value[data-key-value]').forEach(keyElement => {
    keyElement.addEventListener('click', function() {
      const keyValue = this.getAttribute('data-key-value');
      const range = document.createRange();
      range.selectNodeContents(this);
      const selection = window.getSelection();
      selection.removeAllRanges();
      selection.addRange(range);
      
      // Try to copy
      try {
        document.execCommand('copy');
        showCopySuccess(this);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
  });
});

function copyKeyToClipboard(keyValue, button) {
  navigator.clipboard.writeText(keyValue).then(() => {
    const originalHTML = button.innerHTML;
    button.innerHTML = '<span class="btn-icon">✅</span><span class="btn-text">Đã sao chép!</span>';
    button.style.background = '#10b981';
    setTimeout(() => {
      button.innerHTML = originalHTML;
      button.style.background = '';
    }, 2000);
  }).catch(err => {
    console.error('Failed to copy:', err);
    alert('Không thể sao chép. Vui lòng chọn và sao chép thủ công.');
  });
}

function showCopySuccess(element) {
  const originalBg = element.style.background;
  element.style.background = 'rgba(22, 163, 74, 0.3)';
  setTimeout(() => {
    element.style.background = originalBg;
  }, 1000);
}
</script>


