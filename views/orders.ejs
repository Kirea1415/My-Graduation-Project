<div class="orders-container">
  <div class="orders-header">
    <h1>💳 Lịch sử giao dịch</h1>
    <p class="header-subtitle">Xem lại lịch sử mua hàng và key của bạn</p>
  </div>

  <!-- Password Verification Form -->
  <% if (needsPasswordVerification) { %>
    <div class="password-verification-section">
      <div class="password-verification-box">
        <div class="verification-header">
          <div class="lock-icon">🔒</div>
          <h2>Xác thực mật khẩu</h2>
          <p class="verification-subtitle">Vui lòng nhập mật khẩu để xem lịch sử giao dịch và key của bạn</p>
        </div>
        
        <% if (typeof flash !== 'undefined' && flash.error && flash.error.length) { %>
          <div class="error-message">
            <%= flash.error.join('<br/>') %>
          </div>
        <% } %>

        <form method="POST" action="/orders/verify-password" class="verification-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-group">
            <label for="password">Mật khẩu</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autofocus
              class="password-input"
              placeholder="Nhập mật khẩu của bạn..."
            />
          </div>
          <button type="submit" class="btn primary">Xác nhận</button>
        </form>
      </div>
    </div>
  <% } %>
  
  <!-- Only show orders if password is verified -->
  <% if (!needsPasswordVerification) { %>
    <% if (!orders || orders.length === 0) { %>
      <div class="empty-orders">
        <div class="empty-icon">📭</div>
        <h3>Bạn chưa có giao dịch nào</h3>
        <p class="muted">Bắt đầu mua sắm để có giao dịch đầu tiên!</p>
        <a href="/" class="btn primary">Khám phá sản phẩm</a>
      </div>
    <% } else { %>
      <div class="orders-grid">
      <% orders.forEach(o => { %>
        <div class="order-card">
          <div class="order-header">
            <div class="order-info">
              <h3 class="order-number">Giao dịch #<%= o.id %></h3>
              <p class="order-date">
                <span>📅</span>
                <strong><%= new Date(o.created_at).toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></strong>
                <span style="margin: 0 8px;">•</span>
                <span><%= new Date(o.created_at).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }) %></span>
              </p>
            </div>
            <div class="order-status">
              <%
                const statusConfig = {
                  'pending': { label: 'Chờ xử lý', color: '#f59e0b', icon: '⏳' },
                  'processing': { label: 'Đang xử lý', color: '#3b82f6', icon: '⚙️' },
                  'paid': { label: 'Đã thanh toán', color: '#10b981', icon: '✅' },
                  'completed': { label: 'Hoàn thành', color: '#10b981', icon: '✅' },
                  'cancelled': { label: 'Đã hủy', color: '#ef4444', icon: '❌' },
                  'failed': { label: 'Thất bại', color: '#ef4444', icon: '❌' }
                };
                const status = statusConfig[o.status || 'pending'] || statusConfig['pending'];
                const bgColor = status.color + '20';
                const textColor = status.color;
                const borderColor = status.color;
              %>
              <span class="status-badge" 
                    data-bg-color="<%- bgColor %>" 
                    data-text-color="<%- textColor %>" 
                    data-border-color="<%- borderColor %>">
                <span><%= status.icon %></span>
                <%= status.label %>
              </span>
            </div>
          </div>
          
          <div class="order-items">
            <h4 class="items-title">📦 Sản phẩm đã mua:</h4>
            <div class="items-list">
              <% (itemsByOrder[o.id] || []).forEach(it => { %>
                <div class="order-item">
                  <% if (it.image) { %>
                    <div class="item-image">
                      <img src="<%= it.image %>" alt="<%= it.title %>" />
                    </div>
                  <% } %>
                  <div class="item-info">
                    <strong class="item-title"><%= it.title %></strong>
                    <div class="item-details">
                      <span class="item-meta">Số lượng: <strong><%= it.quantity %></strong></span>
                      <span class="item-meta">Giá: <strong><%= (it.price_cents/100).toLocaleString('vi-VN',{style:'currency',currency:'VND'}) %></strong></span>
                    </div>
                    <div class="item-subtotal">
                      Thành tiền: <strong><%= ((it.price_cents * it.quantity)/100).toLocaleString('vi-VN',{style:'currency',currency:'VND'}) %></strong>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
            
            <!-- Show keys section only for paid/completed orders -->
            <% const hasKeys = (itemsByOrder[o.id] || []).some(it => keysByOrderItem && keysByOrderItem[it.id] && keysByOrderItem[it.id].length > 0); %>
            <% if (o.status === 'paid' || o.status === 'completed') { %>
              <!-- Show keys if available -->
              <% if (hasKeys) { %>
              <div class="order-keys-section">
                <div class="keys-section-header">
                  <h5 class="keys-title"><%= keyDisplayTitle || '🔑 Key của bạn' %></h5>
                  <a href="/orders/<%= o.id %>/keys" class="btn-view-keys" target="_blank">Xem chi tiết →</a>
                </div>
                <% if (keyDisplayMessage && (!currentUser || currentUser.role !== 'admin')) { %>
                  <p class="keys-message"><%= keyDisplayMessage %></p>
                <% } %>
                
                <div class="keys-list">
                  <% (itemsByOrder[o.id] || []).forEach(it => { %>
                    <% if (keysByOrderItem && keysByOrderItem[it.id] && keysByOrderItem[it.id].length > 0) { %>
                      <% keysByOrderItem[it.id].forEach((keyValue, idx) => { %>
                        <div class="key-item">
                          <div class="key-content">
                            <div class="key-label">🔑 Key <%= keysByOrderItem[it.id].length > 1 ? (idx + 1) : '' %>: <%= it.title %></div>
                            <code class="key-value" data-key-value="<%= keyValue %>"><%= keyValue %></code>
                          </div>
                          <div class="key-actions">
                            <button class="btn-copy-key" data-key-value="<%= keyValue %>" type="button" title="Sao chép key">
                              <span class="btn-icon">📋</span>
                              <span class="btn-text">Sao chép</span>
                            </button>
                          </div>
                        </div>
                      <% }) %>
                    <% } %>
                  <% }) %>
                </div>
                <div class="keys-note">
                  <span class="note-icon">💡</span>
                  <span>Bạn có thể sao chép key bằng cách nhấn nút "Sao chép" hoặc click vào key để chọn</span>
                </div>
              </div>
              <% } else { %>
                <!-- Order is paid/completed but no keys yet -->
                <div class="order-keys-section">
                  <div class="keys-empty">
                    <span class="empty-icon">⏳</span>
                    <p>Chưa có key cho sản phẩm này. Vui lòng liên hệ admin để được hỗ trợ.</p>
                  </div>
                </div>
              <% } %>
            <% } %>
          </div>
          
          <div class="order-footer">
            <div class="order-total">
              <strong>Tổng cộng:</strong>
              <span class="total-price"><%= ((o.total_cents || 0)/100).toLocaleString('vi-VN',{style:'currency',currency:'VND'}) %></span>
            </div>
            
            <div class="order-actions">
              <% const hasKeysInOrder = (itemsByOrder[o.id] || []).some(it => keysByOrderItem && keysByOrderItem[it.id] && keysByOrderItem[it.id].length > 0); %>
              <% if (hasKeysInOrder) { %>
                <a href="/orders/<%= o.id %>/keys" class="btn primary small" target="_blank">
                  🔑 Xem tất cả Key
                </a>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
      </div>
    <% } %>
  <% } %>
</div>

