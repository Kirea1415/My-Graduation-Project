 
<h1>Quản lý Tin tức</h1>
<div class="grid">
  <div class="card"><div class="p">
    <h3>Thêm bài viết</h3>
    <form action="/admin/news?_csrf=<%= csrfToken %>" method="post">
      <div class="row" style="gap:8px;flex-wrap:wrap">
        <input name="title" placeholder="Tiêu đề" required style="flex:1;padding:10px;border-radius:8px;border:1px solid #1f2937;background:#0f172a;color:#fff" />
        <input name="slug" placeholder="slug (tự tạo nếu bỏ trống)" style="flex:1;padding:10px;border-radius:8px;border:1px solid #1f2937;background:#0f172a;color:#fff" />
        <input name="author" placeholder="Tác giả" style="width:200px;padding:10px;border-radius:8px;border:1px solid #1f2937;background:#0f172a;color:#fff" />
        <input name="thumbnail" placeholder="Ảnh đại diện (URL)" style="flex:1;padding:10px;border-radius:8px;border:1px solid #1f2937;background:#0f172a;color:#fff" />
        <select name="published" style="padding:10px;border-radius:8px;border:1px solid #1f2937;background:#0f172a;color:#fff">
          <option value="1">Hiển thị</option>
          <option value="0">Ẩn</option>
        </select>
      </div>
      <textarea name="content" rows="6" placeholder="Nội dung" style="margin-top:8px;width:100%;padding:10px;border-radius:8px;border:1px solid #1f2937;background:#0f172a;color:#fff"></textarea>
      <button class="btn primary" type="submit" style="margin-top:8px">Đăng</button>
    </form>
  </div></div>

  <div class="card"><div class="p">
    <h3>Danh sách bài viết</h3>
    <form class="row" action="/admin/news" method="get" style="gap:8px;margin-bottom:8px">
      <input type="text" name="q" placeholder="Tìm tiêu đề/nội dung" value="<%= typeof q !== 'undefined' ? q : '' %>" style="flex:1;padding:10px;border-radius:8px;border:1px solid #1f2937;background:#0f172a;color:#fff" />
      <button class="btn">Lọc</button>
    </form>
    <table>
      <thead><tr><th>Tiêu đề</th><th>Slug</th><th>Tác giả</th><th>Trạng thái</th><th></th></tr></thead>
      <tbody>
        <% posts.forEach(p => { %>
          <tr>
            <td>
              <% if (p.thumbnail) { %>
                <img src="<%= p.thumbnail %>" alt="" style="width:56px;height:36px;object-fit:cover;border-radius:4px;border:1px solid #1f2937;margin-right:6px;vertical-align:middle" />
              <% } %>
              <a href="/news/<%= p.slug %>" target="_blank"><%= p.title %></a>
            </td>
            <td><%= p.slug %></td>
            <td><%= p.author || '-' %></td>
            <td>
              <form action="/admin/news/<%= p.id %>/toggle?_csrf=<%= csrfToken %>" method="post" style="display:inline">
                <button class="btn"><%= p.published ? 'Ẩn' : 'Hiển thị' %></button>
              </form>
            </td>
            <td>
              <div class="row">
                <a class="btn" href="/admin/news/<%= p.id %>/edit">Sửa</a>
                <form action="/admin/news/<%= p.id %>/delete?_csrf=<%= csrfToken %>" method="post" onsubmit="return confirm('Xóa bài viết này?')">
                  <button class="btn">Xóa</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <div class="row" style="justify-content:center;gap:8px;margin-top:8px">
      <% if (page > 1) { %>
        <a class="btn" href="/admin/news?<%= q ? ('q=' + encodeURIComponent(q) + '&') : '' %>page=<%= page - 1 %>">← Trang trước</a>
      <% } %>
      <% if (totalPages && page < totalPages) { %>
        <a class="btn" href="/admin/news?<%= q ? ('q=' + encodeURIComponent(q) + '&') : '' %>page=<%= page + 1 %>">Trang sau →</a>
      <% } %>
    </div>
  </div></div>
</div>


